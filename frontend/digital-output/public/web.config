<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>

        <!-- Keep existing transform if needed -->
        <rule name="TransformApi" stopProcessing="true">
          <match url="^transform/(.*)" />
          <action type="Rewrite" url="http://localhost:8000/{R:1}" appendQueryString="true" />
        </rule>

        <!-- DEV API calls -> backend DEV instance -->
        <rule name="Dev_BackendProxy" stopProcessing="true">
          <match url="^dev/(health|media|document/.*|pdf/.*|output/web|output/pdf|output/[^/]+/(document|pdf))$" />
          <action type="Rewrite" url="http://localhost:4100/api/{R:1}" appendQueryString="true" />
        </rule>

        <!-- QA API calls -> backend QA instance -->
        <rule name="Qa_BackendProxy" stopProcessing="true">
          <match url="^qa/(health|media|document/.*|pdf/.*|output/web|output/pdf|output/[^/]+/(document|pdf))$" />
          <action type="Rewrite" url="http://localhost:4101/api/{R:1}" appendQueryString="true" />
        </rule>

        <!-- (Optional) keep old non-prefixed /api/* routes on main instance -->
        <rule name="Main_BackendProxy" stopProcessing="true">
          <match url="^(health|media|document/.*|pdf/.*|output/web|output/pdf|output/[^/]+/(document|pdf))$" />
          <action type="Rewrite" url="http://localhost:4000/api/{R:0}" appendQueryString="true" />
        </rule>

        <!-- DEV SPA routes (e.g. /api/dev/output/{id}) -->
        <rule name="Dev_SPA_Fallback" stopProcessing="true">
          <match url="^dev/(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/api/index.html" />
        </rule>

        <!-- QA SPA routes (e.g. /api/qa/output/{id}) -->
        <rule name="Qa_SPA_Fallback" stopProcessing="true">
          <match url="^qa/(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/api/index.html" />
        </rule>

        <!-- Existing default SPA fallback -->
        <rule name="SPA_Fallback" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/api/index.html" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>