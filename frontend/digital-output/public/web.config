<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>

        <!-- Transform service -->
        <rule name="TransformApi" stopProcessing="true">
          <match url="^transform/(.*)" />
          <action type="Rewrite" url="http://localhost:8000/{R:1}" appendQueryString="true" />
        </rule>

        <!-- DEV output creation -->
        <rule name="Dev_Output_Create" stopProcessing="true">
          <match url="^dev/output/(web|pdf)$" />
          <action type="Rewrite" url="http://localhost:4100/api/output/{R:1}" appendQueryString="true" />
        </rule>

        <!-- QA output creation -->
        <rule name="Qa_Output_Create" stopProcessing="true">
          <match url="^qa/output/(web|pdf)$" />
          <action type="Rewrite" url="http://localhost:4101/api/output/{R:1}" appendQueryString="true" />
        </rule>

        <!-- DEV direct backend APIs -->
        <rule name="Dev_Backend_Routes" stopProcessing="true">
          <match url="^dev/(health|media|document/.*|pdf/.*)$" />
          <action type="Rewrite" url="http://localhost:4100/api/{R:1}" appendQueryString="true" />
        </rule>

        <!-- QA direct backend APIs -->
        <rule name="Qa_Backend_Routes" stopProcessing="true">
          <match url="^qa/(health|media|document/.*|pdf/.*)$" />
          <action type="Rewrite" url="http://localhost:4101/api/{R:1}" appendQueryString="true" />
        </rule>

        <!-- Output session resolution by prefixed outputId -->
        <rule name="Dev_Output_Session" stopProcessing="true">
          <match url="^output/dev-[^/]+/(document|pdf)$" />
          <action type="Rewrite" url="http://localhost:4100/api/{R:0}" appendQueryString="true" />
        </rule>

        <rule name="Qa_Output_Session" stopProcessing="true">
          <match url="^output/qa-[^/]+/(document|pdf)$" />
          <action type="Rewrite" url="http://localhost:4101/api/{R:0}" appendQueryString="true" />
        </rule>

        <rule name="Main_Output_Session" stopProcessing="true">
          <match url="^output/main-[^/]+/(document|pdf)$" />
          <action type="Rewrite" url="http://localhost:4000/api/{R:0}" appendQueryString="true" />
        </rule>

        <!-- Backward compatibility for old non-prefixed output IDs -->
        <rule name="Legacy_Output_Session" stopProcessing="true">
          <match url="^output/[0-9a-f]+/(document|pdf)$" />
          <action type="Rewrite" url="http://localhost:4000/api/{R:0}" appendQueryString="true" />
        </rule>

        <!-- Main APIs -->
        <rule name="Main_BackendProxy" stopProcessing="true">
          <match url="^(health|media|document/.*|pdf/.*|output/web|output/pdf)$" />
          <action type="Rewrite" url="http://localhost:4000/api/{R:0}" appendQueryString="true" />
        </rule>

        <!-- Single-frontend SPA fallback -->
        <rule name="SPA_Fallback" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/api/index.html" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>