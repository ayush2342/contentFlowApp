# -----------------------------------------------------------------------------
# Backend .env template — copy to .env and fill values for that environment.
#
# Environment mapping (IIS / RDP):
#   main → DIGITAL_OUTPUT_BASE_URL=.../api,     OUTPUT_ID_PREFIX=main, S3_REQUEST_PREFIX=main
#   dev  → DIGITAL_OUTPUT_BASE_URL=.../api-dev, OUTPUT_ID_PREFIX=dev,  S3_REQUEST_PREFIX=dev
#   qa   → DIGITAL_OUTPUT_BASE_URL=.../api-qa,  OUTPUT_ID_PREFIX=qa,   S3_REQUEST_PREFIX=qa
#
# Local Vite:
#   BASE_URL / DIGITAL_OUTPUT_BASE_URL / PDF_OUTPUT_BASE_URL → http://localhost:5173/api
#   PORT → 4000 (or your local backend port)
# -----------------------------------------------------------------------------

# Public site origin (no path suffix)
BASE_URL=<public-base-url>

# Where the web viewer is hosted (returned in POST /output/web "url")
# main: https://<host>/api | dev: https://<host>/api-dev | qa: https://<host>/api-qa
# local: http://localhost:5173/api
DIGITAL_OUTPUT_BASE_URL=<digital-output-base-url>

# Base used for PDF-related links (usually same host as BASE_URL)
PDF_OUTPUT_BASE_URL=<pdf-output-base-url>

# Prefix for in-memory output session ids (main | dev | qa)
OUTPUT_ID_PREFIX=<main|dev|qa>

# Backend listen port (main / dev / qa each use their own port on the RDP host)
PORT=<port>

# Default stylesheet when templateId is omitted or unknown (theme1 | theme2 | …)
DEFAULT_THEME_ID=theme2

# S3 key pattern for stylesheets. Placeholders: {prefix}, {templateId}
# Example resolved key: <S3_REQUEST_PREFIX>/stylesheets/theme2.json
# Until real objects exist, S3 fetch fails → local shared/themes/{templateId}.json
STYLESHEET_S3_KEY_TEMPLATE={prefix}/stylesheets/{templateId}.json

AWS_REGION=<aws-region>
S3_BUCKET=<s3-bucket-name>
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>

# S3 folder prefix for documents + stylesheets (must match env: main | dev | qa)
S3_REQUEST_PREFIX=<main|dev|qa>

PDF_CACHE_TTL_SECONDS=900
OUTPUT_SESSION_TTL_SECONDS=86400

# Absolute paths on the machine that runs InDesign (leave empty to skip PDF locally)
INDESIGN_EXE_PATH=<path-to-InDesign.exe>
INDESIGN_SCRIPT_PATH=<path-to-populate-indesign.jsx>
INDESIGN_TEMPLATE_PATH=<path-to-projectX.indd>
INDESIGN_TIMEOUT_MS=300000
